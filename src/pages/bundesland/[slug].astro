---
import Layout from '../../layouts/Layout.astro';
import { getAllBundeslandPages, getAllPlzPages, slugify } from '../../utils/geoData.js';

export async function getStaticPaths() {
  const allStates = getAllBundeslandPages();
  const allPlz = getAllPlzPages();

  return allStates.map((state) => {
    // Filter all PLZ entries that belong to this specific Bundesland
    const districtsInState = allPlz.filter(
      (p) => p.bundesland.toLowerCase().trim() === state.bundesland.toLowerCase().trim()
    );

    // Group them to find unique Landkreise for this state
    const uniqueDistricts = {};
    districtsInState.forEach((p) => {
      const dSlug = slugify(p.landkreis);
      if (p.landkreis && p.landkreis.trim() !== "" && dSlug) {
        if (!uniqueDistricts[dSlug]) {
          uniqueDistricts[dSlug] = {
            landkreis: p.landkreis.trim(),
            slug: dSlug
          };
        }
      }
    });

    const districtsArray = Object.values(uniqueDistricts).sort((a, b) => 
      a.landkreis.localeCompare(b.landkreis, 'de')
    );

    return {
      params: { slug: state.stateCode.toLowerCase().trim() },
      props: { 
        bundesland: state.bundesland, 
        stateCode: state.stateCode,
        districts: districtsArray
      },
    };
  });
}

const { bundesland, stateCode, districts } = Astro.props;
const { slug } = Astro.params;

// SEO Metadata
const title = `Postleitzahlen in ${bundesland} – Alle Landkreise & Orte`;
const description = `Suchen Sie Postleitzahlen in ${bundesland}? Hier finden Sie eine komplette Übersicht aller Landkreise im Bundesland ${bundesland}.`;

// Breadcrumbs
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: bundesland, url: `/bundesland/${slug}` }
];
---

<Layout 
  title={title} 
  description={description} 
  breadcrumbs={breadcrumbs}
>
  <div class="hero-section">
    <div class="hero-content">
      <div class="state-badge">DE-{stateCode.toUpperCase()}</div>
      <h1>Postleitzahlen in {bundesland}</h1>
      <p class="intro-text">
        Übersicht aller Landkreise und kreisfreien Städte in <strong>{bundesland}</strong>. 
        Wählen Sie einen Kreis aus, um die zugehörigen Städte und Postleitzahlen anzuzeigen.
      </p>
    </div>
  </div>

  <article class="bundesland-container">
    <section class="districts-section">
      <div class="section-header">
        <h2>Landkreise & Kreisfreie Städte</h2>
        <span class="count-badge">{districts.length} Landkreise</span>
      </div>

      <div class="districts-grid">
        {districts.map((district) => {
          const displayLandkreis = district.landkreis.toLowerCase().startsWith('landkreis') 
            ? district.landkreis 
            : `Landkreis ${district.landkreis}`;
            
          return (
            <a href={`/landkreis/${district.slug}`} class="district-card">
              <div class="district-info">
                <span class="district-name">{displayLandkreis}</span>
                <span class="district-meta">{bundesland}</span>
              </div>
              <div class="arrow-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="arrow-icon"><path d="m9 18 6-6-6-6"/></svg>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </article>
</Layout>

<style>
  .hero-section {
    background: linear-gradient(to bottom, #f8fafc, #ffffff);
    padding: 4rem 1rem;
    margin: -2rem -2rem 3rem -2rem;
    border-bottom: 1px solid #e2e8f0;
    text-align: center;
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .state-badge {
    display: inline-block;
    background: #2563eb;
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .intro-text {
    font-size: 1.125rem;
    color: #475569;
    line-height: 1.6;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #f1f5f9;
  }

  .section-header h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1e293b;
  }

  .count-badge {
    background: #f1f5f9;
    color: #64748b;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .districts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .district-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    text-decoration: none;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .district-card:hover {
    border-color: #2563eb;
    background: #f8fbff;
    box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.1);
    transform: translateY(-2px);
  }

  .district-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .district-name {
    font-weight: 700;
    font-size: 1.125rem;
    color: #1e293b;
  }

  .district-meta {
    font-size: 0.875rem;
    color: #64748b;
  }

  .arrow-wrapper {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f1f5f9;
    border-radius: 9999px;
    color: #94a3b8;
    transition: all 0.2s ease;
  }

  .district-card:hover .arrow-wrapper {
    background: #2563eb;
    color: white;
  }

  @media (max-width: 640px) {
    .districts-grid {
      grid-template-columns: 1fr;
    }
    
    h1 {
      font-size: 2rem;
    }
  }
</style>
